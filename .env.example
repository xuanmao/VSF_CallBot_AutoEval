# --- Gemini Live ---------------------------------------------------------
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-google-ai-studio-key
GEMINI_LIVE_MODEL=gemini-3.1-flash-live

# Voice for Gemini Live TTS (Aoede, Charon, Fenrir, Kore, Puck, ...)
GEMINI_VOICE=Aoede

# --- FreeSWITCH ----------------------------------------------------------
# Password the softphone uses to register as extension 1000
SIP_EXT_1000_PASSWORD=change-me

# Public/LAN IP FreeSWITCH should advertise in SIP/SDP. Use "auto-nat" when
# the softphone runs on the same machine as Docker, otherwise set the real
# LAN IP of the host (e.g. 192.168.1.42).
FS_EXTERNAL_IP=auto-nat

# --- Bridge --------------------------------------------------------------
# Port the bridge listens on inside its container. Don't change unless you
# also update the dialplan and docker-compose.yml.
BRIDGE_PORT=8080
LOG_LEVEL=INFO
